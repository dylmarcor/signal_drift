# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
# production
/build
/.next/
/out/

# production
/build/

# misc
.DS_Store
*.pem

# editor
.vscode/
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# dotenv: ignore local envs, keep examples
.env.local
.env.*.local
!.env.example

# vercel
.vercel/

# typescript
*.tsbuildinfo

# Rust
/target/
**/target/
**/*.rs.bk

# Environment files
.env
.env.*
!.env.example

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Logs
*.log
